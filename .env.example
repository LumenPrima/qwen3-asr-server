# Qwen3-ASR P25 Server Configuration
# Copy to .env and modify as needed.

# Path to the fine-tuned ASR model directory
MODEL_PATH=qwen3-asr-p25-0.6B

# Path to the forced aligner model directory
ALIGNER_PATH=Qwen3-ForcedAligner-0.6B

# GPU device (e.g. cuda:0, cuda:1, cpu)
DEVICE=cuda:0

# Model precision (bfloat16, float16, float32)
DTYPE=bfloat16

# Max tokens the model can generate per transcription
MAX_NEW_TOKENS=512

# Server bind address and port
HOST=0.0.0.0
PORT=8765

# Number of uvicorn workers (keep 1 unless you have multiple GPUs)
WORKERS=1

# RMS energy threshold for speech detection.
# Audio below this is treated as silence/encrypted and skipped.
# P25 tuning: blank <0.003, real speech >0.03
SPEECH_RMS_THRESHOLD=0.01
